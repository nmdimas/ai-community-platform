{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'agents.title'|trans }} — Admin{% endblock %}
{% block page_title %}{{ 'agents.title'|trans }}{% endblock %}

{% block content %}
    <div class="glass-card state-legend">
        <h2>{{ 'agents.state_legend'|trans }}</h2>
        <div class="state-legend-grid">
            <div class="state-legend-item">
                <span class="badge badge-enabled">{{ 'agents.state.enabled'|trans }}</span>
                <span class="state-hint">{{ 'agents.state.enabled_hint'|trans }}</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-disabled">{{ 'agents.state.disabled'|trans }}</span>
                <span class="state-hint">{{ 'agents.state.disabled_hint'|trans }}</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-unknown">{{ 'agents.state.not_installed'|trans }}</span>
                <span class="state-hint">{{ 'agents.state.not_installed_hint'|trans }}</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-healthy">{{ 'agents.state.healthy'|trans }}</span>
                <span class="state-hint">{{ 'agents.state.healthy_hint'|trans }}</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-degraded">{{ 'agents.state.degraded'|trans }}</span>
                <span class="state-hint">{{ 'agents.state.degraded_hint'|trans }}</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-unavailable">{{ 'agents.state.unavailable'|trans }}</span>
                <span class="state-hint">{{ 'agents.state.unavailable_hint'|trans }}</span>
            </div>
        </div>
    </div>

    <div class="action-bar">
        <span id="discoverResult" class="action-result" style="display:none"></span>
        <button class="btn btn-discover" id="discoverBtn" onclick="runDiscovery()">{{ 'agents.discover'|trans }}</button>
    </div>

    <div class="agent-tabs" role="tablist" aria-label="Agent sections">
        <button class="btn btn-tab active" id="tab-installed-btn" type="button" onclick="switchTab('installed')">
            {{ 'agents.tab.installed'|trans }} ({{ installed_agents|length }})
        </button>
        <button class="btn btn-tab" id="tab-marketplace-btn" type="button" onclick="switchTab('marketplace')">
            {{ 'agents.tab.marketplace'|trans }} ({{ marketplace_agents|length }})
        </button>
    </div>

    <div id="tab-installed" class="agent-tab-pane active">
        {% include 'admin/_agents_table.html.twig' with {
            agents: installed_agents,
            mode: 'installed',
            empty_message: 'agents.empty_installed'|trans
        } only %}
    </div>

    <div id="tab-marketplace" class="agent-tab-pane">
        {% include 'admin/_agents_table.html.twig' with {
            agents: marketplace_agents,
            mode: 'marketplace',
            empty_message: 'agents.empty_marketplace'|trans
        } only %}
    </div>

    <div class="modal-overlay" id="violationsModal" onclick="closeModal(event)">
        <div class="modal">
            <h3 id="modalTitle">{{ 'agents.violations'|trans }}</h3>
            <ul id="modalList"></ul>
            <button class="btn btn-disable modal-close" onclick="document.getElementById('violationsModal').classList.remove('active')">{{ 'agents.close'|trans }}</button>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
var discoveringText = '{{ 'agents.discovering'|trans|e('js') }}';
var discoverBtnText = '{{ 'agents.discover'|trans|e('js') }}';

function runDiscovery() {
    var btn = document.getElementById('discoverBtn');
    var result = document.getElementById('discoverResult');
    btn.disabled = true;
    btn.textContent = discoveringText;
    result.style.display = 'none';

    fetch('{{ path('admin_agents_discover') }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        result.textContent = '{{ 'agents.discovered'|trans|e('js') }}'.replace('%count%', data.discovered);
        result.style.color = 'var(--success)';
        result.style.display = 'inline';
        btn.disabled = false;
        btn.textContent = discoverBtnText;
        setTimeout(function() { location.reload(); }, 1000);
    })
    .catch(function() {
        result.textContent = '{{ 'agents.error.request'|trans|e('js') }}';
        result.style.color = 'var(--danger)';
        result.style.display = 'inline';
        btn.disabled = false;
        btn.textContent = discoverBtnText;
    });
}

function switchTab(tab) {
    var installedBtn = document.getElementById('tab-installed-btn');
    var marketplaceBtn = document.getElementById('tab-marketplace-btn');
    var installedPane = document.getElementById('tab-installed');
    var marketplacePane = document.getElementById('tab-marketplace');

    if (tab === 'installed') {
        installedBtn.classList.add('active');
        marketplaceBtn.classList.remove('active');
        installedPane.classList.add('active');
        marketplacePane.classList.remove('active');
        return;
    }

    installedBtn.classList.remove('active');
    marketplaceBtn.classList.add('active');
    installedPane.classList.remove('active');
    marketplacePane.classList.add('active');
}

function extractError(response) {
    return response.clone().json()
        .then(function(body) { return body.error || ('{{ 'agents.error.status'|trans|e('js') }}'.replace('%status%', response.status)); })
        .catch(function() { return '{{ 'agents.error.status'|trans|e('js') }}'.replace('%status%', response.status); });
}

function installAgent(name) {
    if (!confirm('{{ 'agents.confirm.install'|trans|e('js') }}'.replace('%name%', name))) return;

    fetch('/api/v1/internal/agents/' + encodeURIComponent(name) + '/install', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        if (r.ok) {
            location.reload();
            return;
        }

        extractError(r).then(function(message) {
            alert(message);
        });
    })
    .catch(function() { alert('{{ 'agents.error.network'|trans|e('js') }}'); });
}

function toggleAgent(name, action) {
    var label = action === 'enable' ? '{{ 'agents.action.enable'|trans|e('js') }}' : '{{ 'agents.action.disable'|trans|e('js') }}';
    if (!confirm('{{ 'agents.confirm.toggle'|trans|e('js') }}'.replace('%action%', label).replace('%name%', name))) return;

    fetch('/api/v1/internal/agents/' + encodeURIComponent(name) + '/' + action, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        if (r.ok) {
            location.reload();
            return;
        }

        extractError(r).then(function(message) {
            alert(message);
        });
    })
    .catch(function() { alert('{{ 'agents.error.network'|trans|e('js') }}'); });
}

function deleteAgent(name) {
    if (!confirm('{{ 'agents.confirm.delete'|trans|e('js') }}'.replace('%name%', name))) return;

    fetch('/api/v1/internal/agents/' + encodeURIComponent(name), {
        method: 'DELETE',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        if (r.ok) {
            location.reload();
            return;
        }

        extractError(r).then(function(message) {
            alert(message);
        });
    })
    .catch(function() { alert('{{ 'agents.error.network'|trans|e('js') }}'); });
}

function showViolations(name, violations) {
    var list = document.getElementById('modalList');
    document.getElementById('modalTitle').textContent = '{{ 'agents.violations_for'|trans|e('js') }}'.replace('%name%', name);
    list.innerHTML = '';

    var items = violations;
    if (typeof violations === 'string') {
        try {
            items = JSON.parse(violations);
        } catch (e) {
            items = [violations];
        }
    }

    if (!Array.isArray(items) || items.length === 0) {
        items = ['No details'];
    }

    items.forEach(function(v) {
        var li = document.createElement('li');
        li.textContent = String(v);
        list.appendChild(li);
    });

    document.getElementById('violationsModal').classList.add('active');
}

function closeModal(e) {
    if (e.target === document.getElementById('violationsModal')) {
        e.target.classList.remove('active');
    }
}
</script>
{% endblock %}
