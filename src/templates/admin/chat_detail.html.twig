{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'chat_detail.title'|trans }} — {{ trace_id[:30] }} — Admin{% endblock %}
{% block page_title %}{{ 'chat_detail.title'|trans }}{% endblock %}

{% block content %}
    <div class="glass-card" style="margin-bottom:1rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;">
            <div>
                <a href="{{ path('admin_chats') }}" style="font-size:.85rem;color:var(--text-secondary);">{{ 'chat_detail.back'|trans }}</a>
                <h2 style="margin:.5rem 0 .25rem;font-size:1rem;">{{ 'chat_detail.trace_id'|trans }}</h2>
                <code style="font-size:.8rem;color:var(--text-secondary);word-break:break-all;">{{ trace_id }}</code>
            </div>
            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                {% for tid in trace_ids[:5] %}
                    <a href="{{ path('admin_log_trace', {traceId: tid}) }}" class="btn btn-settings" title="{{ tid }}">
                        <svg viewBox="0 0 24 24" style="width:14px;height:14px;fill:currentColor;"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zM6 20V4h7v5h5v11H6z"/></svg>
                        Trace {{ tid[:12] }}…
                    </a>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="glass-card">
        {% if messages is empty %}
            <div class="stub-content" style="min-height:200px;">
                <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z"/></svg>
                <p>{{ 'chat_detail.no_messages'|trans }}</p>
                <p style="font-size:.85rem;">{{ 'chat_detail.not_indexed'|trans }}</p>
            </div>
        {% else %}
            <div class="chat-conversation">
                {% for msg in messages %}
                    {% if msg.direction == 'inbound' %}
                        <div class="chat-bubble chat-bubble-inbound">
                            <div class="chat-bubble-header">
                                <span class="chat-bubble-sender">{{ msg.sender ?? 'chat_detail.user'|trans }}</span>
                                <span class="chat-bubble-time">{{ msg.timestamp[:19]|replace({'T': ' '}) }}</span>
                            </div>
                            <div class="chat-bubble-body">
                                {% if msg.payload.text is defined %}
                                    {{ msg.payload.text }}
                                {% elseif msg.payload is not empty %}
                                    <pre>{{ msg.payload|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                                {% else %}
                                    <span class="text-muted">[{{ 'chat_detail.empty_message'|trans }}]</span>
                                {% endif %}
                            </div>
                        </div>
                    {% elseif msg.direction == 'outbound' %}
                        <div class="chat-bubble chat-bubble-outbound">
                            <div class="chat-bubble-header">
                                <span class="chat-bubble-sender">{{ 'chat_detail.bot'|trans }}</span>
                                <span class="chat-bubble-time">{{ msg.timestamp[:19]|replace({'T': ' '}) }}</span>
                            </div>
                            <div class="chat-bubble-body">
                                {% if msg.payload.text is defined %}
                                    {{ msg.payload.text }}
                                {% elseif msg.payload is not empty %}
                                    <pre>{{ msg.payload|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                                {% else %}
                                    <span class="text-muted">[{{ 'chat_detail.empty_message'|trans }}]</span>
                                {% endif %}
                            </div>
                        </div>
                    {% elseif msg.direction in ['tool_call', 'tool_result', 'tool_error'] %}
                        <div class="chat-tool-event chat-tool-{{ msg.direction }}">
                            <div class="chat-tool-header">
                                <svg viewBox="0 0 24 24" style="width:14px;height:14px;fill:currentColor;flex-shrink:0;"><path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/></svg>
                                {% if msg.direction == 'tool_call' %}
                                    <span>{{ 'chat_detail.tool_call'|trans }}: <strong>{{ msg.tool ?? 'unknown' }}</strong></span>
                                {% elseif msg.direction == 'tool_result' %}
                                    <span>{{ 'chat_detail.tool_result'|trans }}: <strong>{{ msg.tool ?? 'unknown' }}</strong></span>
                                    {% if msg.durationMs is not null %}
                                        <span class="chat-tool-duration">{{ msg.durationMs }}ms</span>
                                    {% endif %}
                                {% elseif msg.direction == 'tool_error' %}
                                    <span>{{ 'chat_detail.tool_error'|trans }}: <strong>{{ msg.tool ?? 'unknown' }}</strong></span>
                                {% endif %}
                                {% if msg.traceId is not null %}
                                    <a href="{{ path('admin_log_trace', {traceId: msg.traceId}) }}" class="chat-tool-trace" onclick="event.stopPropagation();">trace</a>
                                {% endif %}
                                <span class="chat-bubble-time">{{ msg.timestamp[:19]|replace({'T': ' '}) }}</span>
                            </div>
                            {% if msg.payload is not empty %}
                                <details class="chat-tool-payload">
                                    <summary>Payload</summary>
                                    <pre>{{ msg.payload|json_encode(constant('JSON_PRETTY_PRINT') b-or constant('JSON_UNESCAPED_UNICODE')) }}</pre>
                                </details>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
