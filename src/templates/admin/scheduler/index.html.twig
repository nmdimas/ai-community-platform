{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'scheduler.title'|trans }} — Admin{% endblock %}
{% block page_title %}{{ 'scheduler.title'|trans }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://esm.sh/@vue-js-cron/light@5.1.1/dist/light.css">
    <style>
        /* @vue-js-cron/light — library has built-in .dark .ant theme, we just add .dark class */
        #cron-builder-app { font-size: .85rem; }
        #cron-builder-app .cron-light { flex-wrap: wrap; gap: .3rem; }
        /* Prefix/infix text */
        #cron-builder-app .cl-prefix { color: var(--text-secondary, #94a3b8); }
        /* Give the builder wrap breathing room */
        #cron-builder-wrap { padding: .5rem 0; min-height: 3rem; }
    </style>
    <script type="importmap">
    {
        "imports": {
            "vue": "https://esm.sh/vue@3.5.13/dist/vue.esm-browser.prod.js",
            "@vue-js-cron/light": "https://esm.sh/@vue-js-cron/light@5.1.1?bundle-deps&external=vue"
        }
    }
    </script>
{% endblock %}

{% block content %}
    <div class="stats-grid" style="margin-bottom:1rem;">
        <div class="stat-card">
            <div class="stat-label">{{ 'scheduler.stat.jobs'|trans }}</div>
            <div class="stat-value">{{ stats.total_jobs }}</div>
            <div style="font-size:.7rem;color:var(--text-muted);margin-top:.2rem;">
                {{ 'scheduler.stat.enabled'|trans({'%enabled%': stats.enabled_jobs, '%disabled%': stats.disabled_jobs}) }}
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">{{ 'scheduler.stat.runs_24h'|trans }}</div>
            <div class="stat-value text-success">{{ stats.runs_24h }}</div>
            <div style="font-size:.7rem;color:var(--text-muted);margin-top:.2rem;">
                {{ 'scheduler.stat.runs_detail'|trans({'%completed%': stats.completed_24h, '%failed%': stats.failed_24h}) }}
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">{{ 'scheduler.stat.problems'|trans }}</div>
            <div class="stat-value{% if stats.failed_jobs > 0 or stats.stale_jobs > 0 %} text-danger{% endif %}">{{ stats.failed_jobs + stats.stale_jobs }}</div>
            <div style="font-size:.7rem;color:var(--text-muted);margin-top:.2rem;">
                {{ 'scheduler.stat.problem_detail'|trans({'%failed%': stats.failed_jobs, '%stale%': stats.stale_jobs}) }}
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-label">{{ 'scheduler.stat.last_run'|trans }}</div>
            <div class="stat-value" style="font-size:1rem;">
                {% if stats.last_run %}
                    {{ stats.last_run|date('H:i:s') }}
                {% else %}
                    —
                {% endif %}
            </div>
            <div style="font-size:.7rem;color:var(--text-muted);margin-top:.2rem;">
                {% if stats.last_run %}{{ stats.last_run|date('d.m.Y') }}{% else %}{{ 'scheduler.stat.no_data'|trans }}{% endif %}
            </div>
        </div>
    </div>

    <div class="glass-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;">
            <span style="font-size:.85rem;color:var(--text-secondary);">{{ 'scheduler.total'|trans({'%count%': jobs|length}) }}</span>
            <button class="btn btn-primary" style="font-size:.8rem;padding:.4rem .8rem;" onclick="document.getElementById('createJobModal').classList.add('active')">{{ 'scheduler.create'|trans }}</button>
        </div>

        <div style="overflow-x:auto;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>{{ 'scheduler.table.agent'|trans }}</th>
                        <th>{{ 'scheduler.table.job'|trans }}</th>
                        <th>{{ 'scheduler.table.skill'|trans }}</th>
                        <th>{{ 'scheduler.table.cron'|trans }}</th>
                        <th>{{ 'scheduler.table.next_run'|trans }}</th>
                        <th>{{ 'scheduler.table.last_run'|trans }}</th>
                        <th>{{ 'scheduler.table.status'|trans }}</th>
                        <th>{{ 'scheduler.table.enabled'|trans }}</th>
                        <th>{{ 'scheduler.table.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for job in jobs %}
                        <tr{% if job._stale %} style="background:rgba(239,68,68,.08);"{% endif %}>
                            <td style="width:1.5rem;text-align:center;">
                                {% if job._stale %}
                                    <span title="{{ job._stale_reason }}" style="cursor:help;color:#ef4444;font-size:1.1rem;">&#9888;</span>
                                {% elseif (job.source ?? 'manifest') == 'admin' %}
                                    <span title="{{ 'scheduler.created_in_admin'|trans }}" style="cursor:help;color:var(--text-muted);font-size:.85rem;">&#9998;</span>
                                {% endif %}
                            </td>
                            <td>{{ job.agent_name }}</td>
                            <td>{{ job.job_name }}</td>
                            <td style="font-family:monospace;font-size:.8rem;">{{ job.skill_id }}</td>
                            <td style="font-family:monospace;font-size:.8rem;">{{ job.cron_expression ?? '—' }}</td>
                            <td style="font-size:.85rem;white-space:nowrap;">{{ job.next_run_at ? job.next_run_at|slice(0, 19)|replace({'T': ' '}) : '—' }}</td>
                            <td style="font-size:.85rem;white-space:nowrap;">{{ job.last_run_at ? job.last_run_at|slice(0, 19)|replace({'T': ' '}) : '—' }}</td>
                            <td>
                                {% if job._stale %}
                                    <span class="badge badge-log-critical" title="{{ job._stale_reason }}">stale</span>
                                {% elseif job.last_status == 'completed' %}
                                    <span class="badge badge-log-info">completed</span>
                                {% elseif job.last_status == 'failed' %}
                                    <span class="badge badge-log-error">failed</span>
                                {% elseif job.last_status == 'dead_letter' %}
                                    <span class="badge badge-log-critical">dead_letter</span>
                                {% else %}
                                    <span style="color:var(--text-muted);">{{ job.last_status ?? '—' }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if job.enabled %}
                                    <span class="badge badge-log-info">{{ 'scheduler.enabled_yes'|trans }}</span>
                                {% else %}
                                    <span class="badge badge-log-error">{{ 'scheduler.enabled_no'|trans }}</span>
                                {% endif %}
                            </td>
                            <td style="white-space:nowrap;">
                                <a
                                    class="btn btn-settings"
                                    style="font-size:.75rem;padding:.25rem .6rem;text-decoration:none;"
                                    href="{{ path('admin_scheduler_logs', {id: job.id}) }}"
                                >{{ 'scheduler.action.logs'|trans }}</a>
                                <button
                                    class="btn btn-settings"
                                    style="font-size:.75rem;padding:.25rem .6rem;margin-left:.25rem;"
                                    onclick="runNow('{{ job.id|e('js') }}')"
                                >{{ 'scheduler.action.run'|trans }}</button>
                                <button
                                    class="btn btn-settings"
                                    style="font-size:.75rem;padding:.25rem .6rem;margin-left:.25rem;"
                                    onclick="toggleJob('{{ job.id|e('js') }}', {{ job.enabled ? 'false' : 'true' }})"
                                >{{ job.enabled ? 'scheduler.action.disable'|trans : 'scheduler.action.enable'|trans }}</button>
                                {% if (job.source ?? 'manifest') == 'admin' %}
                                    <button
                                        class="btn btn-settings"
                                        style="font-size:.75rem;padding:.25rem .6rem;margin-left:.25rem;color:#ef4444;"
                                        onclick="deleteJob('{{ job.id|e('js') }}', '{{ job.job_name|e('js') }}')"
                                    >{{ 'scheduler.action.delete'|trans }}</button>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="10" class="empty-row">{{ 'scheduler.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div id="createJobModal" class="modal-overlay" onclick="if(event.target===this)this.classList.remove('active')">
        <div class="modal" style="max-width:90%;width:720px;">
            <h3>{{ 'scheduler.modal.title'|trans }}</h3>
            <form id="createJobForm" onsubmit="createJob(event)">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.75rem;">
                    <div>
                        <label class="form-label" for="cj_agent">{{ 'scheduler.modal.agent'|trans }}</label>
                        <select id="cj_agent" class="form-input" required onchange="onAgentChange()">
                            <option value="">{{ 'scheduler.modal.agent_placeholder'|trans }}</option>
                            {% for agent in agents %}
                                <option value="{{ agent }}">{{ agent }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="cj_skill">{{ 'scheduler.modal.skill'|trans }}</label>
                        <select id="cj_skill" class="form-input" required disabled>
                            <option value="">{{ 'scheduler.modal.skill_placeholder'|trans }}</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.75rem;">
                    <div>
                        <label class="form-label" for="cj_job_name">{{ 'scheduler.modal.job_name'|trans }}</label>
                        <input type="text" id="cj_job_name" class="form-input" required placeholder="daily-greeting">
                    </div>
                    <div>
                        <label class="form-label">
                            {{ 'scheduler.modal.cron'|trans }}
                            <button type="button" id="cronModeToggle" class="btn btn-settings" style="font-size:.65rem;padding:.15rem .4rem;margin-left:.4rem;vertical-align:middle;" onclick="toggleCronMode()">{{ 'scheduler.modal.cron_visual'|trans }}</button>
                        </label>
                        <input type="text" id="cj_cron" class="form-input" placeholder="0 9 * * *">
                        <div id="cron-builder-wrap" style="display:none;margin-top:.35rem;">
                            <div id="cron-builder-app" class="dark"></div>
                        </div>
                    </div>
                </div>
                <div style="margin-bottom:.75rem;">
                    <label class="form-label" for="cj_payload">{{ 'scheduler.modal.payload'|trans }}</label>
                    <input type="text" id="cj_payload" class="form-input" placeholder='{"name": "Дмитро"}'>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;margin-bottom:1rem;">
                    <div>
                        <label class="form-label" for="cj_timezone">{{ 'scheduler.modal.timezone'|trans }}</label>
                        <input type="text" id="cj_timezone" class="form-input" value="UTC" placeholder="Europe/Kyiv">
                    </div>
                    <div>
                        <label class="form-label" for="cj_retries">{{ 'scheduler.modal.retries'|trans }}</label>
                        <input type="number" id="cj_retries" class="form-input" value="3" min="0" max="10">
                    </div>
                    <div>
                        <label class="form-label" for="cj_delay">{{ 'scheduler.modal.delay'|trans }}</label>
                        <input type="number" id="cj_delay" class="form-input" value="60" min="1">
                    </div>
                </div>
                <div style="display:flex;gap:.5rem;align-items:center;justify-content:flex-end;">
                    <span id="createJobResult" style="font-size:.85rem;display:none;"></span>
                    <button type="button" class="btn btn-settings" onclick="document.getElementById('createJobModal').classList.remove('active')">{{ 'scheduler.modal.cancel'|trans }}</button>
                    <button type="submit" class="btn btn-primary" id="createJobBtn">{{ 'scheduler.modal.submit'|trans }}</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
var agentSkillMap = {{ agent_skill_map|json_encode|raw }};

function onAgentChange() {
    var agentName = document.getElementById('cj_agent').value;
    var skillSelect = document.getElementById('cj_skill');
    skillSelect.innerHTML = '';

    if (!agentName || !agentSkillMap[agentName] || agentSkillMap[agentName].length === 0) {
        skillSelect.innerHTML = '<option value="">{{ 'scheduler.modal.no_skills'|trans|e('js') }}</option>';
        skillSelect.disabled = true;
        return;
    }

    var skills = agentSkillMap[agentName];
    skillSelect.disabled = false;
    skills.forEach(function(sid) {
        var opt = document.createElement('option');
        opt.value = sid;
        opt.textContent = sid;
        skillSelect.appendChild(opt);
    });
}

function runNow(id) {
    fetch('/api/v1/internal/scheduler/' + id + '/run', {method: 'POST'})
        .then(r => r.json())
        .then(() => location.reload())
        .catch(e => alert('Error: ' + e));
}

function toggleJob(id, enable) {
    fetch('/api/v1/internal/scheduler/' + id + '/toggle', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({enabled: enable})
    })
        .then(r => r.json())
        .then(() => location.reload())
        .catch(e => alert('Error: ' + e));
}

function deleteJob(id, name) {
    if (!confirm('{{ 'scheduler.confirm.delete'|trans({'%name%': ''})|e('js') }}'.replace('%name%', name))) return;
    fetch('/api/v1/internal/scheduler/' + id, {method: 'DELETE'})
        .then(function(r) { return r.json().then(function(b) { return {ok: r.ok, body: b}; }); })
        .then(function(res) {
            if (res.ok) {
                location.reload();
            } else {
                alert(res.body.error || 'Помилка видалення');
            }
        })
        .catch(e => alert('Error: ' + e));
}

function createJob(e) {
    e.preventDefault();
    var btn = document.getElementById('createJobBtn');
    var result = document.getElementById('createJobResult');
    btn.disabled = true;
    btn.textContent = '{{ 'scheduler.modal.creating'|trans|e('js') }}';
    result.style.display = 'none';

    var data = {
        agent_name: document.getElementById('cj_agent').value,
        job_name: document.getElementById('cj_job_name').value,
        skill_id: document.getElementById('cj_skill').value,
        cron_expression: document.getElementById('cj_cron').value,
        payload: document.getElementById('cj_payload').value,
        timezone: document.getElementById('cj_timezone').value,
        max_retries: parseInt(document.getElementById('cj_retries').value, 10),
        retry_delay_seconds: parseInt(document.getElementById('cj_delay').value, 10)
    };

    fetch('/api/v1/internal/scheduler/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(data)
    })
    .then(function(r) { return r.json().then(function(b) { return {ok: r.ok, body: b}; }); })
    .then(function(res) {
        if (res.ok) {
            location.reload();
        } else {
            result.textContent = res.body.error || '{{ 'scheduler.modal.error'|trans|e('js') }}';
            result.style.color = 'var(--danger)';
            result.style.display = 'inline';
        }
    })
    .catch(function() {
        result.textContent = '{{ 'scheduler.modal.network_error'|trans|e('js') }}';
        result.style.color = 'var(--danger)';
        result.style.display = 'inline';
    })
    .finally(function() {
        btn.disabled = false;
        btn.textContent = '{{ 'scheduler.modal.submit'|trans|e('js') }}';
    });
}

var cronBuilderVisible = false;
function toggleCronMode() {
    cronBuilderVisible = !cronBuilderVisible;
    var wrap = document.getElementById('cron-builder-wrap');
    var input = document.getElementById('cj_cron');
    var btn = document.getElementById('cronModeToggle');

    if (cronBuilderVisible) {
        wrap.style.display = 'block';
        input.style.display = 'none';
        btn.textContent = '{{ 'scheduler.modal.cron_text'|trans|e('js') }}';
        initCronBuilder();
    } else {
        wrap.style.display = 'none';
        input.style.display = '';
        btn.textContent = '{{ 'scheduler.modal.cron_visual'|trans|e('js') }}';
    }
}

var cronBuilderInited = false;
function initCronBuilder() {
    if (cronBuilderInited) return;
    cronBuilderInited = true;

    if (typeof window.__mountCronBuilder === 'function') {
        window.__mountCronBuilder();
    } else {
        window.__cronBuilderRequested = true;
    }
}
</script>
<script type="module">
import { createApp, ref, watch } from 'vue';
import { CronLight } from '@vue-js-cron/light';

function mountCronBuilder() {
    const cronInput = document.getElementById('cj_cron');
    const app = createApp({
        components: { CronLight },
        setup() {
            const value = ref(cronInput.value || '* * * * *');

            watch(value, function(v) {
                cronInput.value = v;
                cronInput.dispatchEvent(new Event('input'));
            });

            cronInput.addEventListener('input', function() {
                const wrap = document.getElementById('cron-builder-wrap');
                if (wrap && wrap.style.display === 'none') {
                    value.value = cronInput.value || '* * * * *';
                }
            });

            return { value };
        },
        template: '<cron-light v-model="value" />'
    });
    app.mount('#cron-builder-app');
}

window.__mountCronBuilder = mountCronBuilder;

if (window.__cronBuilderRequested) {
    mountCronBuilder();
}
</script>
{% endblock %}
