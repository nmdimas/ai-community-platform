{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'logs.title'|trans }} — {{ job.job_name }} — Admin{% endblock %}
{% block page_title %}{{ 'logs.title'|trans }}: {{ job.agent_name }} / {{ job.job_name }}{% endblock %}

{% block content %}
    <div style="margin-bottom:.75rem;">
        <a href="{{ path('admin_scheduler') }}" class="btn btn-settings" style="font-size:.8rem;padding:.35rem .7rem;">{{ 'scheduler_logs.back'|trans }}</a>
        <span style="margin-left:.75rem;font-size:.85rem;color:var(--text-secondary);">
            {{ 'scheduler_logs.skill'|trans }}: <code style="font-size:.8rem;">{{ job.skill_id }}</code> &middot; {{ 'scheduler_logs.cron'|trans }}: <code style="font-size:.8rem;">{{ job.cron_expression ?? 'scheduler_logs.one_time'|trans }}</code> &middot; {{ 'scheduler_logs.total'|trans({'%count%': total}) }}
        </span>
    </div>

    <div class="glass-card">
        <div style="overflow-x:auto;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>{{ 'scheduler_logs.table.start'|trans }}</th>
                        <th>{{ 'scheduler_logs.table.end'|trans }}</th>
                        <th>{{ 'scheduler_logs.table.duration'|trans }}</th>
                        <th>{{ 'scheduler_logs.table.status'|trans }}</th>
                        <th>{{ 'scheduler_logs.table.error'|trans }}</th>
                        <th>{{ 'scheduler_logs.table.payload'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for log in logs %}
                        <tr>
                            <td style="font-size:.85rem;white-space:nowrap;">{{ log.started_at|slice(0, 19)|replace({'T': ' '}) }}</td>
                            <td style="font-size:.85rem;white-space:nowrap;">{{ log.finished_at ? log.finished_at|slice(0, 19)|replace({'T': ' '}) : '—' }}</td>
                            <td style="font-size:.85rem;white-space:nowrap;">
                                {% if log.finished_at and log.started_at %}
                                    {% set dur = date(log.finished_at).timestamp - date(log.started_at).timestamp %}
                                    {{ dur }}s
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>
                                {% if log.status == 'completed' %}
                                    <span class="badge badge-log-info">completed</span>
                                {% elseif log.status == 'failed' %}
                                    <span class="badge badge-log-error">failed</span>
                                {% elseif log.status == 'running' %}
                                    <span class="badge badge-log-warning">running</span>
                                {% else %}
                                    <span style="color:var(--text-muted);">{{ log.status }}</span>
                                {% endif %}
                            </td>
                            <td style="font-size:.8rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ log.error_message ?? '' }}">
                                {{ log.error_message ?? '—' }}
                            </td>
                            <td style="font-family:monospace;font-size:.75rem;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ log.payload_sent }}">
                                {{ log.payload_sent }}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="empty-row">{{ 'scheduler_logs.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if total_pages > 1 %}
            <div style="display:flex;justify-content:center;gap:.5rem;margin-top:1rem;">
                {% if page > 1 %}
                    <a href="{{ path('admin_scheduler_logs', {id: job.id, page: page - 1}) }}" class="btn btn-settings" style="font-size:.8rem;padding:.3rem .6rem;">{{ 'scheduler_logs.prev'|trans }}</a>
                {% endif %}
                <span style="font-size:.85rem;color:var(--text-secondary);padding:.3rem .5rem;">{{ page }} / {{ total_pages }}</span>
                {% if page < total_pages %}
                    <a href="{{ path('admin_scheduler_logs', {id: job.id, page: page + 1}) }}" class="btn btn-settings" style="font-size:.8rem;padding:.3rem .6rem;">{{ 'scheduler_logs.next'|trans }}</a>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endblock %}
