{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'logs.title'|trans }} — Admin{% endblock %}
{% block page_title %}{{ 'logs.title'|trans }}{% endblock %}

{% block content %}
    <div class="glass-card" style="margin-bottom:1rem;">
        <form method="get" action="{{ path('admin_logs') }}" class="log-filter-form">
            <div class="log-filter-row">
                <div class="log-filter-field" style="flex:2;">
                    <label class="form-label" for="q">{{ 'logs.search'|trans }}</label>
                    <input type="text" id="q" name="q" class="form-input" value="{{ q }}" placeholder="{{ 'logs.search_placeholder'|trans }}">
                </div>
                <div class="log-filter-field">
                    <label class="form-label" for="level">{{ 'logs.level'|trans }}</label>
                    <select id="level" name="level" class="form-input">
                        <option value="">{{ 'logs.all'|trans }}</option>
                        {% for l in levels %}
                            <option value="{{ l }}" {{ level == l ? 'selected' : '' }}>{{ l }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="log-filter-field">
                    <label class="form-label" for="category">{{ 'logs.category'|trans }}</label>
                    <select id="category" name="category" class="form-input">
                        <option value="">{{ 'logs.all'|trans }}</option>
                        {% for key, cat in categories %}
                            <option value="{{ key }}" {{ category == key ? 'selected' : '' }}>{{ cat.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="log-filter-field">
                    <label class="form-label" for="app">{{ 'logs.app'|trans }}</label>
                    <select id="app" name="app" class="form-input">
                        <option value="">{{ 'logs.all'|trans }}</option>
                        {% for a in apps %}
                            <option value="{{ a }}" {{ app_filter == a ? 'selected' : '' }}>{{ a }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="log-filter-field">
                    <label class="form-label" for="from">{{ 'logs.date_from'|trans }}</label>
                    <input type="date" id="from" name="from" class="form-input" value="{{ date_from }}">
                </div>
                <div class="log-filter-field">
                    <label class="form-label" for="to">{{ 'logs.date_to'|trans }}</label>
                    <input type="date" id="to" name="to" class="form-input" value="{{ date_to }}">
                </div>
                <div class="log-filter-field" style="align-self:flex-end;">
                    <button type="submit" class="btn btn-primary">{{ 'logs.submit'|trans }}</button>
                </div>
            </div>
        </form>
    </div>

    <div class="glass-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;">
            <span style="font-size:.85rem;color:var(--text-secondary);">{{ 'logs.found'|trans({total: total}) }}</span>
        </div>

        <div style="overflow-x:auto;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width:160px;">{{ 'logs.table.time'|trans }}</th>
                        <th style="width:80px;">{{ 'logs.table.level'|trans }}</th>
                        <th style="width:130px;">{{ 'logs.table.app'|trans }}</th>
                        <th>{{ 'logs.table.message'|trans }}</th>
                        <th style="width:100px;">{{ 'logs.table.trace'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for hit in hits %}
                        <tr>
                            <td style="font-family:monospace;font-size:.8rem;white-space:nowrap;">{{ hit['@timestamp']|default('')|slice(0, 19)|replace({'T': ' '}) }}</td>
                            <td>
                                {% set ln = hit.level_name|default('UNKNOWN') %}
                                <span class="badge badge-log-{{ ln|lower }}">{{ ln }}</span>
                            </td>
                            <td style="font-size:.85rem;">{{ hit.app_name|default('—') }}</td>
                            <td>
                                <div class="log-message">{{ hit.message|default('')|slice(0, 200) }}</div>
                                {% if hit.exception is defined and hit.exception.class is defined %}
                                    <details style="margin-top:.3rem;">
                                        <summary style="font-size:.8rem;color:var(--danger);cursor:pointer;">{{ hit.exception.class }}: {{ hit.exception.message|default('')|slice(0, 100) }}</summary>
                                        <pre style="max-height:200px;overflow:auto;margin-top:.3rem;">{{ hit.exception.trace|default('') }}</pre>
                                    </details>
                                {% endif %}
                                {% if hit.request_uri is defined %}
                                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.2rem;">{{ hit.request_method|default('') }} {{ hit.request_uri }}</div>
                                {% endif %}
                            </td>
                            <td>
                                {% if hit.trace_id is defined and hit.trace_id %}
                                    <a href="{{ path('admin_log_trace', {traceId: hit.trace_id}) }}" style="font-family:monospace;font-size:.75rem;" title="{{ hit.trace_id }}">{{ hit.trace_id|slice(0, 8) }}…</a>
                                {% else %}
                                    <span style="color:var(--text-muted);">—</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="empty-row">{{ 'logs.empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if pages > 1 %}
            <div class="log-pagination">
                {% if page > 1 %}
                    <a href="{{ path('admin_logs', {q: q, level: level, category: category, app: app_filter, from: date_from, to: date_to, page: page - 1}) }}" class="btn btn-settings">{{ 'logs.prev'|trans }}</a>
                {% endif %}
                <span style="color:var(--text-secondary);font-size:.85rem;">{{ 'logs.page_info'|trans({page: page, pages: pages}) }}</span>
                {% if page < pages %}
                    <a href="{{ path('admin_logs', {q: q, level: level, category: category, app: app_filter, from: date_from, to: date_to, page: page + 1}) }}" class="btn btn-settings">{{ 'logs.next'|trans }}</a>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endblock %}
