{% extends 'admin/layout.html.twig' %}

{% block title %}Створити тенант — Admin{% endblock %}
{% block page_title %}Створити тенант{% endblock %}

{% block content %}
<div class="card" style="max-width:500px;">
    {% if error %}
    <div style="margin-bottom:1rem;padding:.6rem;background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);border-radius:6px;color:#ef4444;font-size:.85rem;">
        {{ error }}
    </div>
    {% endif %}

    <form method="post" action="{{ path('admin_tenant_create') }}">
        <div style="margin-bottom:1rem;">
            <label style="display:block;font-size:.85rem;margin-bottom:.35rem;color:var(--text-muted);">Назва тенанта</label>
            <input type="text" name="name" required autofocus
                   style="width:100%;padding:.5rem .75rem;background:var(--input-bg,#1a1a2e);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:.9rem;"
                   placeholder="Назва спільноти">
        </div>
        <div style="display:flex;gap:.5rem;">
            <button type="submit" style="padding:.5rem 1.25rem;background:var(--accent,#3b82f6);color:#fff;border:none;border-radius:6px;font-size:.85rem;cursor:pointer;">
                Створити
            </button>
            <a href="{{ path('admin_tenants') }}" style="padding:.5rem 1.25rem;font-size:.85rem;color:var(--text-muted);text-decoration:none;">
                Скасувати
            </a>
        </div>
    </form>
</div>
{% endblock %}
