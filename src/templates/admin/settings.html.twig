{% extends 'admin/layout.html.twig' %}

{% block title %}{{ 'settings.title'|trans }} — Admin{% endblock %}
{% block page_title %}{{ 'settings.title'|trans }}{% endblock %}

{% block content %}
    {% if saved %}
        <div class="glass-card" style="background:rgba(34,197,94,.12);border:1px solid rgba(34,197,94,.3);margin-bottom:1rem;">
            <p style="margin:0;color:#22c55e;">{{ 'settings.saved'|trans }}</p>
        </div>
    {% endif %}

    <div class="glass-card">
        <h3 style="margin-top:0;margin-bottom:1rem;">{{ 'settings.logging'|trans }}</h3>
        <form method="post" action="{{ path('admin_settings') }}">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1.5rem;">
                <div>
                    <label class="form-label" for="log_level">{{ 'settings.log_level'|trans }}</label>
                    <select id="log_level" name="log_level" class="form-input">
                        {% for l in levels %}
                            <option value="{{ l }}" {{ settings.log_level == l ? 'selected' : '' }}>{{ l }}</option>
                        {% endfor %}
                    </select>
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.3rem;">
                        {{ 'settings.log_level_hint'|trans }}
                    </div>
                </div>
                <div>
                    <label class="form-label" for="retention_days">{{ 'settings.retention_days'|trans }}</label>
                    <input type="number" id="retention_days" name="retention_days" class="form-input"
                           value="{{ settings.retention_days }}" min="1" max="90">
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.3rem;">
                        {{ 'settings.retention_hint'|trans }}
                    </div>
                </div>
                <div>
                    <label class="form-label" for="max_size_gb">{{ 'settings.max_size'|trans }}</label>
                    <input type="number" id="max_size_gb" name="max_size_gb" class="form-input"
                           value="{{ settings.max_size_gb }}" min="1" max="50">
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:.3rem;">
                        {{ 'settings.max_size_hint'|trans }}
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">{{ 'settings.save'|trans }}</button>
        </form>
    </div>
{% endblock %}
