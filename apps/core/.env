APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-this-to-a-secure-random-value-before-deploying
DATABASE_URL=postgresql://app:app@postgres:5432/ai_community_platform?serverVersion=16&charset=utf8
REDIS_URL=redis://redis:6379
APP_INTERNAL_TOKEN=dev-internal-token
OPENCLAW_GATEWAY_TOKEN=dev-openclaw-token
OPENCLAW_DISCOVERY_PUSH_URL=
POSTGRES_PROVISIONER_URL=postgresql://postgres@postgres:5432/postgres?serverVersion=16&charset=utf8
OPENSEARCH_URL=http://opensearch:9200

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# DATABASE_URL is defined above; managed entry kept for Flex compatibility.
###< doctrine/doctrine-bundle ###
