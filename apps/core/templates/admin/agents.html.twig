{% extends 'admin/layout.html.twig' %}

{% block title %}Управління агентами — Admin{% endblock %}
{% block page_title %}Управління агентами{% endblock %}

{% block content %}
    <div class="glass-card state-legend">
        <h2>Пояснення стейтів</h2>
        <div class="state-legend-grid">
            <div class="state-legend-item">
                <span class="badge badge-enabled">Увімкнено</span>
                <span class="state-hint">Агент активний: події та команди маршрутизуються.</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-disabled">Вимкнено</span>
                <span class="state-hint">Агент вимкнений: події та команди не надсилаються.</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-unknown">Не встановлено</span>
                <span class="state-hint">Агент у мережі Docker, але ще не провіжинений у платформі.</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-healthy">Healthy</span>
                <span class="state-hint">Агент доступний та відповідає за конвенціями.</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-degraded">Degraded</span>
                <span class="state-hint">Є порушення конвенцій, але агент частково працює.</span>
            </div>
            <div class="state-legend-item">
                <span class="badge badge-unavailable">Unavailable</span>
                <span class="state-hint">Агент тимчасово недоступний по мережі або health-check.</span>
            </div>
        </div>
    </div>

    <div class="action-bar">
        <span id="discoverResult" class="action-result" style="display:none"></span>
        <button class="btn btn-discover" id="discoverBtn" onclick="runDiscovery()">Виявити агентів</button>
    </div>

    <div class="agent-tabs" role="tablist" aria-label="Agent sections">
        <button class="btn btn-tab active" id="tab-installed-btn" type="button" onclick="switchTab('installed')">
            Встановлені ({{ installed_agents|length }})
        </button>
        <button class="btn btn-tab" id="tab-marketplace-btn" type="button" onclick="switchTab('marketplace')">
            Маркетплейс ({{ marketplace_agents|length }})
        </button>
    </div>

    <div id="tab-installed" class="agent-tab-pane active">
        {% include 'admin/_agents_table.html.twig' with {
            agents: installed_agents,
            mode: 'installed',
            empty_message: 'Немає встановлених агентів. Перейдіть у вкладку «Маркетплейс» та натисніть «Встановити».'
        } only %}
    </div>

    <div id="tab-marketplace" class="agent-tab-pane">
        {% include 'admin/_agents_table.html.twig' with {
            agents: marketplace_agents,
            mode: 'marketplace',
            empty_message: 'Маркетплейс порожній. Натисніть «Виявити агентів», щоб знайти сервіси в Docker.'
        } only %}
    </div>

    <div class="modal-overlay" id="violationsModal" onclick="closeModal(event)">
        <div class="modal">
            <h3 id="modalTitle">Порушення конвенцій</h3>
            <ul id="modalList"></ul>
            <button class="btn btn-disable modal-close" onclick="document.getElementById('violationsModal').classList.remove('active')">Закрити</button>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
function runDiscovery() {
    var btn = document.getElementById('discoverBtn');
    var result = document.getElementById('discoverResult');
    btn.disabled = true;
    btn.textContent = 'Виявлення...';
    result.style.display = 'none';

    fetch('{{ path('admin_agents_discover') }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        result.textContent = 'Виявлено: ' + data.discovered + ' агент(ів)';
        result.style.color = 'var(--success)';
        result.style.display = 'inline';
        btn.disabled = false;
        btn.textContent = 'Виявити агентів';
        setTimeout(function() { location.reload(); }, 1000);
    })
    .catch(function() {
        result.textContent = 'Помилка запиту';
        result.style.color = 'var(--danger)';
        result.style.display = 'inline';
        btn.disabled = false;
        btn.textContent = 'Виявити агентів';
    });
}

function switchTab(tab) {
    var installedBtn = document.getElementById('tab-installed-btn');
    var marketplaceBtn = document.getElementById('tab-marketplace-btn');
    var installedPane = document.getElementById('tab-installed');
    var marketplacePane = document.getElementById('tab-marketplace');

    if (tab === 'installed') {
        installedBtn.classList.add('active');
        marketplaceBtn.classList.remove('active');
        installedPane.classList.add('active');
        marketplacePane.classList.remove('active');
        return;
    }

    installedBtn.classList.remove('active');
    marketplaceBtn.classList.add('active');
    installedPane.classList.remove('active');
    marketplacePane.classList.add('active');
}

function extractError(response) {
    return response.clone().json()
        .then(function(body) { return body.error || ('Помилка: ' + response.status); })
        .catch(function() { return 'Помилка: ' + response.status; });
}

function installAgent(name) {
    if (!confirm('Встановити агент ' + name + '?\n\nБуде виконано провіжинінг сховищ (БД/Redis/OpenSearch) та міграції.')) return;

    fetch('/api/v1/internal/agents/' + encodeURIComponent(name) + '/install', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        if (r.ok) {
            location.reload();
            return;
        }

        extractError(r).then(function(message) {
            alert(message);
        });
    })
    .catch(function() { alert('Помилка мережі'); });
}

function toggleAgent(name, action) {
    var label = action === 'enable' ? 'Увімкнути' : 'Вимкнути';
    if (!confirm(label + ' агент ' + name + '?')) return;

    fetch('/api/v1/internal/agents/' + encodeURIComponent(name) + '/' + action, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        if (r.ok) {
            location.reload();
            return;
        }

        extractError(r).then(function(message) {
            alert(message);
        });
    })
    .catch(function() { alert('Помилка мережі'); });
}

function deleteAgent(name) {
    if (!confirm('Видалити агент ' + name + '?\n\nЦе повністю видалить провіжинінг (БД, Redis, OpenSearch) і поверне агент у вкладку «Маркетплейс».')) return;

    fetch('/api/v1/internal/agents/' + encodeURIComponent(name), {
        method: 'DELETE',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) {
        if (r.ok) {
            location.reload();
            return;
        }

        extractError(r).then(function(message) {
            alert(message);
        });
    })
    .catch(function() { alert('Помилка мережі'); });
}

function showViolations(name, violations) {
    var list = document.getElementById('modalList');
    document.getElementById('modalTitle').textContent = 'Порушення: ' + name;
    list.innerHTML = '';

    var items = violations;
    if (typeof violations === 'string') {
        try {
            items = JSON.parse(violations);
        } catch (e) {
            items = [violations];
        }
    }

    if (!Array.isArray(items) || items.length === 0) {
        items = ['No details'];
    }

    items.forEach(function(v) {
        var li = document.createElement('li');
        li.textContent = String(v);
        list.appendChild(li);
    });

    document.getElementById('violationsModal').classList.add('active');
}

function closeModal(e) {
    if (e.target === document.getElementById('violationsModal')) {
        e.target.classList.remove('active');
    }
}
</script>
{% endblock %}
