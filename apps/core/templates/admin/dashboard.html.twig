{% extends 'admin/layout.html.twig' %}

{% block title %}Статистика — Admin{% endblock %}
{% block page_title %}Статистика{% endblock %}

{% block content %}
    {% set is_local_host = app.request.host in ['localhost', '127.0.0.1'] %}
    {% set show_langfuse = is_local_host or ('localhost' not in admin_langfuse_url and '127.0.0.1' not in admin_langfuse_url) %}
    {% set show_litellm = is_local_host or ('localhost' not in admin_litellm_url and '127.0.0.1' not in admin_litellm_url) %}
    {% set show_openclaw = is_local_host or ('localhost' not in admin_openclaw_url and '127.0.0.1' not in admin_openclaw_url) %}
    {% set show_traefik = is_local_host or ('localhost' not in admin_traefik_url and '127.0.0.1' not in admin_traefik_url) %}

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Всього агентів</div>
            <div class="stat-value">{{ agents_total ?? '—' }}</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Активних агентів</div>
            <div class="stat-value text-success">{{ agents_enabled ?? '—' }}</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Вимкнених агентів</div>
            <div class="stat-value text-danger">{{ agents_disabled ?? '—' }}</div>
        </div>
    </div>

    <div class="glass-card">
        <h2>Ласкаво просимо, {{ username }}</h2>
        <p>Це панель адміністрування AI Community Platform. Використовуйте навігацію зліва для управління системою.</p>
        <div style="margin-top:1rem;display:flex;gap:.6rem;flex-wrap:wrap;">
            {% if show_langfuse %}
                <a class="btn btn-primary" href="{{ admin_langfuse_url }}">Відкрити Langfuse</a>
            {% endif %}
            {% if show_litellm %}
                <a class="btn btn-settings" href="{{ admin_litellm_url }}">Відкрити LiteLLM</a>
            {% endif %}
            {% if show_openclaw %}
                <a class="btn btn-settings" href="{{ admin_openclaw_url }}?token={{ openclaw_gateway_token }}" target="_blank">Відкрити OpenClaw UI</a>
            {% endif %}
            {% if show_traefik %}
                <a class="btn btn-settings" href="{{ admin_traefik_url }}">Відкрити Traefik</a>
            {% endif %}
        </div>
        {% if not is_local_host and (not show_langfuse or not show_litellm or not show_openclaw or not show_traefik) %}
            <p style="margin-top:1rem;color:var(--text-secondary);">
                Частина tool-посилань прихована, бо для цього середовища вони все ще налаштовані на <code>localhost</code>.
            </p>
        {% endif %}
    </div>
{% endblock %}
