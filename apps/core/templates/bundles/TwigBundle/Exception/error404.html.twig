{% extends 'base.html.twig' %}

{% block title %}Page Not Found - AI Community Platform{% endblock %}

{% block body %}
<!-- Google Fonts: Manrope -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #081521;
    --bg-soft: #112538;
    --text: #e8f1fb;
    --muted: #9bb3c8;
    --accent: #26d0ce;
    --accent-2: #1a75ff;
    --border: rgba(255, 255, 255, 0.14);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: "Manrope", "Segoe UI", sans-serif;
    background:
      radial-gradient(circle at 15% 20%, rgba(38, 208, 206, 0.22), transparent 40%),
      radial-gradient(circle at 85% 10%, rgba(26, 117, 255, 0.2), transparent 38%),
      linear-gradient(135deg, var(--bg) 0%, #0b1d2d 55%, #0d2233 100%);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wrap {
    max-width: 600px;
    margin: 0 auto;
    padding: 24px;
    text-align: center;
  }

  .tag {
    display: inline-block;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--accent);
    background: rgba(6, 18, 31, .5);
    margin-bottom: 24px;
  }

  h1 {
    margin: 0 0 16px;
    font-size: clamp(64px, 15vw, 140px);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(90deg, var(--accent), #66e6e4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 800;
  }

  h2 {
    margin: 0 0 12px;
    font-size: clamp(24px, 5vw, 36px);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: clamp(16px, 3vw, 18px);
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 44px;
  }

  .actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    border-radius: 10px;
    padding: 14px 28px;
    font-weight: 700;
    font-size: 15px;
    border: 1px solid transparent;
    transition: transform .14s ease, box-shadow .14s ease;
  }

  .btn:hover { transform: translateY(-2px); }

  .btn-primary {
    color: #04101b;
    background: linear-gradient(90deg, var(--accent), #66e6e4);
    box-shadow: 0 10px 24px rgba(38, 208, 206, .2);
  }

  .btn-secondary {
    color: var(--text);
    border-color: var(--border);
    background: rgba(255, 255, 255, 0.02);
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }

  .floating {
    animation: float 6s ease-in-out infinite;
  }

</style>

<main class="wrap">
  <span class="tag">Error 404</span>
  <h1 class="floating">404</h1>
  <h2>Lost in AI Space?</h2>
  <p class="subtitle">
    The page you are looking for has been moved, deleted, or never existed in this neural network.
    Even our best agents couldn't find it.
  </p>

  <div class="actions">
    <a class="btn btn-primary" href="/">Return to Homepage</a>
    <a class="btn btn-secondary" href="javascript:history.back()">Go Back</a>
  </div>
</main>
{% endblock %}
