<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dev Agent — Task #{{ task.id }}</title>
    <style>
        :root {
            --bg-primary: #0f172a;
            --bg-card: rgba(30,41,59,.7);
            --bg-card-border: rgba(148,163,184,.15);
            --bg-input: rgba(15,23,42,.6);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --success: #22c55e;
            --success-bg: rgba(34,197,94,.15);
            --danger: #ef4444;
            --danger-bg: rgba(239,68,68,.15);
            --warning: #eab308;
            --warning-bg: rgba(234,179,8,.15);
            --info-bg: rgba(59,130,246,.15);
            --radius: 8px;
            --radius-sm: 4px;
            --transition: .2s ease;
        }
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; color: var(--text-primary); background: var(--bg-primary); line-height: 1.5; }
        a { color: var(--accent); text-decoration: none; }

        .page-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--bg-card-border); display: flex; align-items: center; gap: 1rem; }
        .page-header h1 { margin: 0; font-size: 1.1rem; flex: 1; }

        .content { max-width: 1100px; margin: 0 auto; padding: 1.5rem; }

        .card { background: var(--bg-card); border: 1px solid var(--bg-card-border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1rem; backdrop-filter: blur(12px); }
        .card h2 { margin: 0 0 .75rem; font-size: .95rem; color: var(--text-secondary); }

        .meta-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: .75rem; }
        .meta-item { }
        .meta-label { font-size: .75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: .5px; }
        .meta-value { font-size: .9rem; margin-top: .15rem; }

        .badge { display: inline-block; padding: .2rem .5rem; border-radius: var(--radius-sm); font-size: .75rem; font-weight: 600; }
        .badge-success { background: var(--success-bg); color: var(--success); }
        .badge-danger { background: var(--danger-bg); color: var(--danger); }
        .badge-warning { background: var(--warning-bg); color: var(--warning); }
        .badge-info { background: var(--info-bg); color: var(--accent); }
        .badge-muted { background: rgba(148,163,184,.1); color: var(--text-muted); }

        .btn { display: inline-flex; align-items: center; gap: .4rem; padding: .45rem .9rem; border-radius: var(--radius-sm); font-size: .85rem; font-weight: 600; border: none; cursor: pointer; transition: all var(--transition); text-decoration: none; }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-hover); }
        .btn-success { background: var(--success); color: #fff; }
        .btn:disabled { opacity: .5; cursor: not-allowed; }

        .spec-content { white-space: pre-wrap; font-size: .85rem; line-height: 1.7; color: var(--text-secondary); max-height: 300px; overflow-y: auto; }

        /* Log viewer */
        .log-panel { background: #0a0f1a; border-radius: var(--radius); padding: .75rem; max-height: 500px; overflow-y: auto; font-family: 'SF Mono', 'Fira Code', monospace; font-size: .8rem; line-height: 1.6; }
        .log-line { padding: .1rem 0; display: flex; gap: .5rem; }
        .log-time { color: var(--text-muted); flex-shrink: 0; min-width: 6ch; }
        .log-agent { color: var(--accent); font-weight: 600; flex-shrink: 0; min-width: 12ch; }
        .log-message { word-break: break-all; }
        .log-line.log-error .log-message { color: var(--danger); }
        .log-line.log-warn .log-message { color: var(--warning); }

        .status-live { display: inline-flex; align-items: center; gap: .4rem; }
        .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--success); animation: pulse 1.5s ease-in-out infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

        .text-muted { color: var(--text-muted); }
    </style>
</head>
<body>
    <div class="page-header">
        <a href="/admin/tasks" style="color: var(--text-muted);">&larr; Tasks</a>
        <h1>Task #{{ task.id }}: {{ task.title }}</h1>
        {% if task.status in ['draft', 'failed'] %}
            <button class="btn btn-primary" onclick="startPipeline()">Start Pipeline</button>
        {% endif %}
    </div>

    <div class="content">
        <div class="card">
            <h2>Details</h2>
            <div class="meta-grid">
                <div class="meta-item">
                    <div class="meta-label">Status</div>
                    <div class="meta-value" id="task-status">
                        {% if task.status == 'success' %}
                            <span class="badge badge-success">success</span>
                        {% elseif task.status == 'failed' %}
                            <span class="badge badge-danger">failed</span>
                        {% elseif task.status == 'running' %}
                            <span class="status-live"><span class="live-dot"></span> <span class="badge badge-warning">running</span></span>
                        {% elseif task.status == 'pending' %}
                            <span class="badge badge-info">pending</span>
                        {% else %}
                            <span class="badge badge-muted">{{ task.status }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Branch</div>
                    <div class="meta-value">{{ task.branch|default('—') }}</div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Pipeline ID</div>
                    <div class="meta-value">{{ task.pipeline_id|default('—') }}</div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Duration</div>
                    <div class="meta-value">{% if task.duration_seconds %}{{ (task.duration_seconds / 60)|round(1) }}m{% else %}—{% endif %}</div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">PR</div>
                    <div class="meta-value">{% if task.pr_url %}<a href="{{ task.pr_url }}" target="_blank">View PR</a>{% else %}—{% endif %}</div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Created</div>
                    <div class="meta-value">{{ task.created_at|date('Y-m-d H:i') }}</div>
                </div>
            </div>
        </div>

        {% if task.refined_spec %}
        <div class="card">
            <h2>Refined Specification</h2>
            <div class="spec-content">{{ task.refined_spec }}</div>
        </div>
        {% elseif task.description %}
        <div class="card">
            <h2>Description</h2>
            <div class="spec-content">{{ task.description }}</div>
        </div>
        {% endif %}

        <div class="card">
            <h2>
                Pipeline Logs
                {% if task.status in ['running', 'pending'] %}
                    <span class="status-live" style="font-size: .8rem; font-weight: 400; margin-left: .5rem;">
                        <span class="live-dot"></span> Live
                    </span>
                {% endif %}
            </h2>
            <div class="log-panel" id="logs">
                {% for log in logs %}
                    <div class="log-line log-{{ log.level }}">
                        <span class="log-time">{{ log.created_at|date('H:i:s') }}</span>
                        <span class="log-agent">{{ log.agent_step|default('system') }}</span>
                        <span class="log-message">{{ log.message }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>

        {% if task.error_message %}
        <div class="card" style="border-color: rgba(239,68,68,.3);">
            <h2 style="color: var(--danger);">Error</h2>
            <div class="spec-content" style="color: var(--danger);">{{ task.error_message }}</div>
        </div>
        {% endif %}
    </div>

    <script>
        const taskId = {{ task.id }};
        const taskStatus = '{{ task.status }}';

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // SSE for live logs
        if (['running', 'pending'].includes(taskStatus)) {
            const logsEl = document.getElementById('logs');
            let lastId = {{ logs|length > 0 ? logs|last.id : 0 }};

            const source = new EventSource('/admin/tasks/api/' + taskId + '/logs/stream?last_id=' + lastId);

            source.onmessage = function(event) {
                const entry = JSON.parse(event.data);
                const line = document.createElement('div');
                line.className = 'log-line log-' + entry.level;
                line.innerHTML =
                    '<span class="log-time">' + (entry.created_at || '').slice(11, 19) + '</span>' +
                    '<span class="log-agent">' + escapeHtml(entry.agent_step || 'system') + '</span>' +
                    '<span class="log-message">' + escapeHtml(entry.message) + '</span>';
                logsEl.appendChild(line);
                logsEl.scrollTop = logsEl.scrollHeight;
            };

            source.addEventListener('complete', function(event) {
                const data = JSON.parse(event.data);
                source.close();
                // Reload to show final state
                window.location.reload();
            });
        }

        async function startPipeline() {
            const resp = await fetch('/admin/tasks/api/' + taskId + '/start', { method: 'POST' });
            const data = await resp.json();
            if (data.status === 'pending') {
                window.location.reload();
            } else {
                alert('Error: ' + (data.error || 'Unknown'));
            }
        }
    </script>
</body>
</html>
