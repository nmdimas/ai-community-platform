<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dev Agent — New Task</title>
    <style>
        :root {
            --bg-primary: #0f172a;
            --bg-card: rgba(30,41,59,.7);
            --bg-card-border: rgba(148,163,184,.15);
            --bg-input: rgba(15,23,42,.6);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --accent: #3b82f6;
            --accent-hover: #2563eb;
            --success: #22c55e;
            --danger: #ef4444;
            --radius: 8px;
            --radius-sm: 4px;
            --transition: .2s ease;
        }
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 14px; color: var(--text-primary); background: var(--bg-primary); line-height: 1.5; }
        a { color: var(--accent); text-decoration: none; }

        .page-header { padding: 1rem 1.5rem; border-bottom: 1px solid var(--bg-card-border); display: flex; align-items: center; gap: 1rem; }
        .page-header h1 { margin: 0; font-size: 1.1rem; }

        .content { max-width: 900px; margin: 0 auto; padding: 1.5rem; }

        .card { background: var(--bg-card); border: 1px solid var(--bg-card-border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1rem; backdrop-filter: blur(12px); }
        .card h2 { margin: 0 0 1rem; font-size: .95rem; color: var(--text-secondary); }

        label { display: block; margin-bottom: .3rem; font-size: .85rem; color: var(--text-secondary); }
        input[type="text"], textarea { width: 100%; padding: .55rem .75rem; background: var(--bg-input); border: 1px solid var(--bg-card-border); border-radius: var(--radius-sm); color: var(--text-primary); font-size: .9rem; font-family: inherit; resize: vertical; }
        input:focus, textarea:focus { outline: none; border-color: var(--accent); }
        .form-group { margin-bottom: 1rem; }

        .checkbox-group { display: flex; gap: 1.5rem; align-items: center; }
        .checkbox-group label { display: flex; align-items: center; gap: .4rem; margin: 0; cursor: pointer; }

        .btn { display: inline-flex; align-items: center; gap: .4rem; padding: .5rem 1rem; border-radius: var(--radius-sm); font-size: .85rem; font-weight: 600; border: none; cursor: pointer; transition: all var(--transition); }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-hover); }
        .btn-secondary { background: var(--bg-card); border: 1px solid var(--bg-card-border); color: var(--text-secondary); }
        .btn-secondary:hover { color: var(--text-primary); border-color: var(--accent); }
        .btn-success { background: var(--success); color: #fff; }
        .btn:disabled { opacity: .5; cursor: not-allowed; }

        .actions { display: flex; gap: .75rem; margin-top: 1rem; }

        /* Chat UI */
        .chat-container { max-height: 400px; overflow-y: auto; margin-bottom: 1rem; }
        .chat-msg { padding: .6rem .9rem; border-radius: var(--radius); margin-bottom: .5rem; max-width: 85%; white-space: pre-wrap; font-size: .9rem; line-height: 1.6; }
        .chat-msg.user { background: rgba(59,130,246,.15); margin-left: auto; }
        .chat-msg.assistant { background: rgba(148,163,184,.1); }
        .chat-input-row { display: flex; gap: .5rem; }
        .chat-input-row input { flex: 1; }

        .hidden { display: none; }
        .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,.3); border-top-color: #fff; border-radius: 50%; animation: spin .6s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="page-header">
        <a href="/admin/tasks" style="color: var(--text-muted);">&larr; Tasks</a>
        <h1>New Task</h1>
    </div>

    <div class="content">
        <div class="card">
            <h2>Task Description</h2>
            <div class="form-group">
                <label for="title">Title</label>
                <input type="text" id="title" placeholder="Short task title...">
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" rows="5" placeholder="Describe what you want to build or fix..."></textarea>
            </div>
            <div class="form-group">
                <div class="checkbox-group">
                    <label><input type="checkbox" id="skip-architect"> Skip Architect</label>
                    <label><input type="checkbox" id="audit"> Include Auditor</label>
                    <label><input type="checkbox" id="auto-start"> Auto-start pipeline</label>
                </div>
            </div>
            <div class="actions">
                <button class="btn btn-secondary" onclick="refineWithOpus()">Refine with Opus</button>
                <button class="btn btn-primary" onclick="createTask()">Create Task</button>
            </div>
        </div>

        <div id="chat-section" class="card hidden">
            <h2>Opus Refinement</h2>
            <div class="chat-container" id="chat-container"></div>
            <div class="chat-input-row">
                <input type="text" id="chat-input" placeholder="Ask Opus to refine or clarify..." onkeydown="if(event.key==='Enter')sendChat()">
                <button class="btn btn-secondary" onclick="sendChat()" id="chat-send-btn">Send</button>
            </div>
            <div class="actions" style="margin-top: 1rem;">
                <button class="btn btn-success" onclick="acceptAndCreate()">Accept & Create Task</button>
            </div>
        </div>
    </div>

    <script>
        let chatHistory = [];
        let lastAssistantMessage = '';

        function refineWithOpus() {
            const desc = document.getElementById('description').value.trim();
            if (!desc) { alert('Enter a description first'); return; }

            document.getElementById('chat-section').classList.remove('hidden');
            sendMessage(desc);
        }

        function sendChat() {
            const input = document.getElementById('chat-input');
            const msg = input.value.trim();
            if (!msg) return;
            input.value = '';
            sendMessage(msg);
        }

        async function sendMessage(message) {
            const container = document.getElementById('chat-container');
            const btn = document.getElementById('chat-send-btn');

            // Add user message
            const userDiv = document.createElement('div');
            userDiv.className = 'chat-msg user';
            userDiv.textContent = message;
            container.appendChild(userDiv);
            container.scrollTop = container.scrollHeight;

            // Loading
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span>';

            try {
                const resp = await fetch('/admin/tasks/api/refine', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, chat_history: chatHistory })
                });
                const data = await resp.json();

                if (data.error) {
                    alert('Error: ' + data.error);
                    return;
                }

                chatHistory = data.chat_history;
                lastAssistantMessage = data.reply;

                const assistantDiv = document.createElement('div');
                assistantDiv.className = 'chat-msg assistant';
                assistantDiv.textContent = data.reply;
                container.appendChild(assistantDiv);
                container.scrollTop = container.scrollHeight;
            } catch (e) {
                alert('Request failed: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Send';
            }
        }

        async function createTask() {
            const title = document.getElementById('title').value.trim();
            const desc = document.getElementById('description').value.trim();
            if (!title || !desc) { alert('Title and description are required'); return; }

            const body = {
                title,
                description: desc,
                auto_start: document.getElementById('auto-start').checked,
                pipeline_options: {
                    skip_architect: document.getElementById('skip-architect').checked,
                    audit: document.getElementById('audit').checked
                }
            };

            if (lastAssistantMessage) {
                body.refined_spec = lastAssistantMessage;
                body.chat_history = chatHistory;
            }

            const resp = await fetch('/admin/tasks/api/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await resp.json();

            if (data.task_id) {
                window.location.href = '/admin/tasks/' + data.task_id;
            } else {
                alert('Error: ' + (data.error || 'Unknown'));
            }
        }

        function acceptAndCreate() {
            if (lastAssistantMessage) {
                document.getElementById('description').value = lastAssistantMessage;
            }
            createTask();
        }
    </script>
</body>
</html>
