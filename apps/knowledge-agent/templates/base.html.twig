<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}База знань{% endblock %}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f8f9fa; color: #333; }
        .layout { display: flex; min-height: 100vh; }
        .sidebar { width: 280px; background: #1a1a2e; color: #eee; padding: 1.5rem; flex-shrink: 0; overflow-y: auto; }
        .sidebar h2 { color: #e94560; margin-bottom: 1rem; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; }
        .sidebar a { color: #aaa; text-decoration: none; display: block; padding: 0.25rem 0; }
        .sidebar a:hover { color: #fff; }
        .sidebar ul { list-style: none; }
        .sidebar ul li { margin: 0.25rem 0; }
        .sidebar ul ul { padding-left: 1rem; border-left: 1px solid #333; margin-top: 0.25rem; }
        .main { flex: 1; padding: 2rem; overflow-y: auto; }
        .header { background: #fff; padding: 1rem 2rem; border-bottom: 1px solid #e0e0e0; display: flex; align-items: center; gap: 1rem; }
        .header a { text-decoration: none; color: #e94560; font-weight: bold; font-size: 1.2rem; }
        .search-bar { display: flex; gap: 0.5rem; flex: 1; max-width: 600px; }
        .search-bar input { flex: 1; padding: 0.5rem 1rem; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; }
        .search-bar button { padding: 0.5rem 1.5rem; background: #e94560; color: white; border: none; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="header">
        <a href="{{ path('wiki_index') }}">📚 База знань</a>
        <form class="search-bar" action="{{ path('wiki_index') }}" method="get">
            <input type="text" name="q" placeholder="Пошук знань..." value="{{ app.request.query.get('q') }}">
            <button type="submit">Знайти</button>
        </form>
    </div>
    <div class="layout">
        <aside class="sidebar">
            <h2>Дерево знань</h2>
            {% block sidebar %}
                {% include 'wiki/_tree.html.twig' with { tree: tree ?? {} } only %}
            {% endblock %}
        </aside>
        <main class="main">
            {% block content %}{% endblock %}
        </main>
    </div>
</body>
</html>
