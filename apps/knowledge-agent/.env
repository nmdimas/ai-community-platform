APP_ENV=dev
APP_SECRET=knowledge-agent-secret-change-in-prod
DATABASE_URL=postgresql://knowledge_agent:knowledge_agent@postgres:5432/knowledge_agent?serverVersion=16&charset=utf8
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=knowledge_agent_knowledge_entries
RABBITMQ_URL=amqp://app:app@rabbitmq:5672
KNOWLEDGE_WORKER_CONCURRENCY=2
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=dev-key
EMBEDDING_MODEL=text-embedding-3-small
APP_INTERNAL_TOKEN=dev-internal-token
PLATFORM_CORE_URL=http://core
ADMIN_PUBLIC_URL=http://localhost:8083/admin/knowledge

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# DATABASE_URL is set above for Docker environment
###< doctrine/doctrine-bundle ###
